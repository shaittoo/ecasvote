# Copy to .env and adjust. Used by gateway-api (Fabric + Express).

# Database (Prisma)
DATABASE_URL="file:./prisma/dev.db"

# Fabric (test-network-ecasvote, Org1 = SEB)
CHANNEL_NAME=mychannel
CHAINCODE_NAME=ecasvote
MSP_ID=Org1MSP
CRYPTO_PATH=/home/shaina/go/src/github.com/shaittoo/fabric-samples/test-network-ecasvote/organizations/peerOrganizations/org1.example.com
KEY_DIRECTORY_PATH=
CERT_DIRECTORY_PATH=
TLS_CERT_PATH=
PEER_ENDPOINT=localhost:7051
PEER_HOST_ALIAS=peer0.org1.example.com

# Server
PORT=4000

# Paper ballot OpenCV worker (see repo /omr-worker). When unset, scan UI falls back to browser QR only.
OMR_WORKER_URL=http://127.0.0.1:8090
